<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CarTrips.App"
             RequestedThemeVariant="Dark"> 
             
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AppBackgroundColor" Color="#0B1C40"/> 
                    <SolidColorBrush x:Key="CardBackgroundColor" Color="#2A395A"/> 
                    <SolidColorBrush x:Key="PrimaryTextColor" Color="White"/> 
                    <SolidColorBrush x:Key="SecondaryTextColor" Color="#A0ABC0"/> 
                </ResourceDictionary>
                
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AppBackgroundColor" Color="#808f87"/> 
                    <SolidColorBrush x:Key="CardBackgroundColor" Color="White"/> 
                    <SolidColorBrush x:Key="PrimaryTextColor" Color="#725A7A"/> 
                    <SolidColorBrush x:Key="SecondaryTextColor" Color="#0B1C40"/> 
                </ResourceDictionary>
                
            </ResourceDictionary.ThemeDictionaries>
            
       
        <ResourceDictionary.MergedDictionaries>
            <ResourceInclude Source="/Assets/LangUA.axaml" />
        </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>