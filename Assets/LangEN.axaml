    <x:String x:Key="LabelFuelType">Fuel Type</x:String>
    <x:String x:Key="TextElectro">Electric</x:String>
    <x:String x:Key="BtnAddCar">Add Car</x:String>
    <x:String x:Key="MenuHome">Home</x:String>
    <x:String x:Key="MenuAddCar">Add Car</x:String>
    <x:String x:Key="MenuMyCar">Car</x:String>
    <x:String x:Key="MenuHistory">Trip History</x:String>
    <x:String x:Key="TextTotalFuelSpent">Total spent on fuel</x:String>
    <x:String x:Key="TextTotalDistance">Total distance driven</x:String>
    <x:String x:Key="WatermarkDate">Date</x:String>
    <x:String x:Key="WatermarkId">ID</x:String>
    <x:String x:Key="WatermarkDistance">Distance</x:String>
    <x:String x:Key="WatermarkType">Type</x:String>
    <x:String x:Key="BtnSearch">Search</x:String>
    <x:String x:Key="TextTotalTrips">Total trips</x:String>
    <x:String x:Key="TextRecentTrips">Recent trips</x:String>
    <x:String x:Key="TextFilter">Filter ⬆️</x:String>
    <x:String x:Key="TextTotalCars">Total cars</x:String>
    <x:String x:Key="TextTotalSpent">Total spent</x:String>
    <x:String x:Key="LabelId">ID</x:String>
    <x:String x:Key="LabelDeparture">Departure</x:String>
    <x:String x:Key="LabelDestination">Destination</x:String>
    <x:String x:Key="LabelArrivalDate">Arrival date</x:String>
    <x:String x:Key="LabelDistancePanel">Distance</x:String>
    <x:String x:Key="TextAddTripTitle">Add trip</x:String>
    <x:String x:Key="WatermarkDeparture">Departure</x:String>
    <x:String x:Key="WatermarkDestination">Destination</x:String>
    <x:String x:Key="WatermarkDistanceKm">Distance (km)</x:String>
    <x:String x:Key="WatermarkTripType">Trip type</x:String>
    <x:String x:Key="WatermarkCar">Car</x:String>
