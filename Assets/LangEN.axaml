<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <x:String x:Key="TextSettings">Settings</x:String>
    <x:String x:Key="TextTheme">Color Scheme</x:String>
    <x:String x:Key="TextThemeDesc">Switch between light and dark themes</x:String>
    <x:String x:Key="TextThemeLight">Light</x:String>
    <x:String x:Key="TextThemeDark">Dark</x:String>
    <x:String x:Key="TextLanguage">Interface Language</x:String>
    <x:String x:Key="TextLangDesc">Change application language</x:String>
    <x:String x:Key="TextLangEn">English</x:String>
    <x:String x:Key="TextLangUa">Ukrainian</x:String>

    <x:String x:Key="TextTripCenter">Trip Center</x:String>
    <x:String x:Key="TextDiesel">Diesel</x:String>
    <x:String x:Key="TextPetrol">Petrol</x:String>
    
    <x:String x:Key="TitleAddCar">Add New Car</x:String>
    <x:String x:Key="LabelBrand">Brand</x:String>
    <x:String x:Key="WatermarkBrand">e.g., Audi</x:String>
    <x:String x:Key="LabelEngine">Engine Volume</x:String>
    <x:String x:Key="WatermarkEngine">e.g., 2.0</x:String>
    <x:String x:Key="LabelLastService">Last Service</x:String>
    <x:String x:Key="WatermarkService">e.g., 01.01.2026</x:String>
    <x:String x:Key="LabelMileage">Mileage</x:String>
    <x:String x:Key="WatermarkMileage">e.g., 135000 km</x:String>
    <x:String x:Key="LabelConsumption">Average Consumption</x:String>
