<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:CarTrips.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
             x:Class="CarTrips.Views.LoginPanel"
             x:DataType="vm:LoginViewModel"
             x:CompileBindings="False">

    <Grid Background="{DynamicResource AppBackgroundColor}">
       <Border Background="{DynamicResource CardBackgroundColor}"
             CornerRadius="12"
             Width="350"
             HorizontalAlignment="Center"
             VerticalAlignment="Center"
             Padding="25"
             BoxShadow="0 15 40 0 #60000000">
          
          <StackPanel Spacing="15">
             
             <TextBlock Text="{DynamicResource TextLoginTitle}"
                      FontSize="22"
                      FontWeight="Bold"
                      Foreground="{DynamicResource PrimaryTextColor}"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,10"/>

             <StackPanel Spacing="5">
                <TextBlock Text="{DynamicResource TextUsername}" Foreground="{DynamicResource SecondaryTextColor}" FontSize="12"/>
                <TextBox Text="{Binding Username}" 
                       Watermark="{DynamicResource TextLoginWatermark}"
                       Background="{DynamicResource AppBackgroundColor}"
                       Foreground="{DynamicResource PrimaryTextColor}"
                       BorderBrush="{DynamicResource SecondaryTextColor}"
                       CornerRadius="6"
                       Padding="10,8"/>
             </StackPanel>

             <StackPanel Spacing="5">
                <TextBlock Text="{DynamicResource TextPassword}" Foreground="{DynamicResource SecondaryTextColor}" FontSize="12"/>
                <TextBox Text="{Binding Password}" 
                       PasswordChar="*"
                       Watermark="{DynamicResource TextPasswordWatermark}"
                       Background="{DynamicResource AppBackgroundColor}"
                       Foreground="{DynamicResource PrimaryTextColor}"
                       BorderBrush="{DynamicResource SecondaryTextColor}"
                       CornerRadius="6"
                       Padding="10,8"/>
             </StackPanel>

             <TextBlock Text="{Binding ErrorMessage}"
                      Foreground="#FF4D4D"
                      FontSize="13"
                      HorizontalAlignment="Center"
                      TextWrapping="Wrap"
                      IsVisible="{Binding !#ErrorMessage.Text}"/>

             <Button Content="{DynamicResource TextLoginBtn}"
                   Command="{Binding LoginCommand}"
                   Background="#00FF87"
                   Foreground="#0F1626"
                   FontWeight="Bold"
                   FontSize="16"
                   HorizontalAlignment="Stretch"
                   HorizontalContentAlignment="Center"
                   Padding="12"
                   CornerRadius="6"
                   Margin="0,10,0,0"/>

             <Button Content="{DynamicResource TextRegisterBtn}"
                   Command="{Binding RegisterCommand}"
                   Background="Transparent"
                   Foreground="{DynamicResource SecondaryTextColor}"
                   FontWeight="Bold"
                   FontSize="14"
                   HorizontalAlignment="Stretch"
                   HorizontalContentAlignment="Center"
                   Padding="10"
                   Margin="0,0,0,0"/>
             
          </StackPanel>
       </Border>
    </Grid>
</UserControl>