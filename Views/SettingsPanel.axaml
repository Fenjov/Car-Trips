<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CarTrips.ViewModels"
             x:Class="CarTrips.Views.SettingsPanel"
             x:DataType="vm:SettingsViewModel"
             x:CompileBindings="False">

    <Border Background="{DynamicResource CardBackgroundColor}" 
            CornerRadius="20" 
            Padding="30" 
            VerticalAlignment="Stretch" 
            HorizontalAlignment="Stretch">
        
        <DockPanel LastChildFill="False">
            <Label DockPanel.Dock="Top"
                   Content="{DynamicResource TextSettings}" 
                   Foreground="{DynamicResource PrimaryTextColor}" 
                   FontSize="26" 
                   FontWeight="Bold" 
                   Margin="0,0,0,25"
                   Padding="0"/>

            <Button DockPanel.Dock="Bottom"
                    Content="Вийти з акаунту"
                    Command="{Binding LogoutCommand}"
                    Background="#EF4444"
                    Foreground="White"
                    FontWeight="Bold"
                    FontSize="15"
                    Padding="20,12"
                    CornerRadius="10"
                    HorizontalAlignment="Left"
                    Margin="0,30,0,0">
                <Button.Styles>
                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#DC2626"/>
                    </Style>
                </Button.Styles>
            </Button>

            <Grid DockPanel.Dock="Top" ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
                
                <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,20,20">
                    <Label Content="{DynamicResource TextTheme}" Foreground="{DynamicResource PrimaryTextColor}" FontSize="18" Padding="0"/>
                    <Label Content="{DynamicResource TextThemeDesc}" Foreground="{DynamicResource SecondaryTextColor}" FontSize="12" Padding="0" Margin="0,4,0,0"/>
                </StackPanel>
                
                <ToggleSwitch Grid.Row="0" Grid.Column="1" 
                              IsChecked="{Binding IsLightTheme, Mode=TwoWay}" 
                              OnContent="{DynamicResource TextThemeLight}" 
                              OffContent="{DynamicResource TextThemeDark}" 
                              Foreground="{DynamicResource PrimaryTextColor}" 
                              VerticalAlignment="Center"
                              Margin="0,0,0,20"/>

                <StackPanel Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,20,0">
                    <Label Content="{DynamicResource TextLanguage}" Foreground="{DynamicResource PrimaryTextColor}" FontSize="18" Padding="0"/>
                    <Label Content="{DynamicResource TextLangDesc}" Foreground="{DynamicResource SecondaryTextColor}" FontSize="12" Padding="0" Margin="0,4,0,0"/>
                </StackPanel>
                
                <ToggleSwitch Grid.Row="1" Grid.Column="1" 
                              IsChecked="{Binding IsEnglish, Mode=TwoWay}" 
                              OnContent="{DynamicResource TextLangEn}" 
                              OffContent="{DynamicResource TextLangUa}" 
                              Foreground="{DynamicResource PrimaryTextColor}"
                              VerticalAlignment="Center"
                              Margin="0,10,0,0"/>
            </Grid>
        </DockPanel>
    </Border>
</UserControl>