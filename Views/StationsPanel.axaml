<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CarTrips.ViewModels"
             xmlns:models="using:CarTrips.Models"
             x:Class="CarTrips.Views.StationsPanel"
             x:DataType="vm:StationsViewModel"
             x:CompileBindings="False">
    
    <Grid RowDefinitions="Auto, *" Margin="20">
        
        <Border Grid.Row="0" Background="{DynamicResource CardBackgroundColor}" CornerRadius="15" Padding="20" Margin="0,0,0,20">
            <Grid ColumnDefinitions="*, Auto">
                <TextBox Grid.Column="0" 
                         Text="{Binding CityName}" 
                         Watermark="{DynamicResource WatermarkStationCity}" 
                         FontSize="16" Height="45" CornerRadius="10" Margin="0,0,15,0"
                         VerticalContentAlignment="Center"/>
                
                <Button Grid.Column="1" 
                        Content="{DynamicResource BtnSearchStations}" 
                        Command="{Binding SearchStationsCommand}"
                        Background="#00FF7F" Foreground="Black" FontWeight="Bold" FontSize="16"
                        Height="45" CornerRadius="10" Padding="20,0"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="{DynamicResource CardBackgroundColor}" CornerRadius="15" Padding="20">
            <Grid RowDefinitions="Auto, *">
                
                <TextBlock Grid.Row="0" Text="{Binding StatusMessage}" 
                           Foreground="{DynamicResource SecondaryTextColor}" FontSize="14" Margin="0"
                           HorizontalAlignment="Center" FontWeight="SemiBold"/>
                
                <ScrollViewer Grid.Row="1">
                    <Grid>
                        <ProgressBar IsIndeterminate="True" 
                                     IsVisible="{Binding IsLoading}" 
                                     VerticalAlignment="Top" Height="3" Foreground="#00FF7F" Margin="0,0,0,10"/>
                        
                        <ItemsControl ItemsSource="{Binding FoundStations}" Margin="0,10,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:Station">
                                    <Border Background="#1E1E1E" CornerRadius="10" Padding="15" Margin="0,0,0,10" BorderBrush="#333333" BorderThickness="1">
                                        <Grid ColumnDefinitions="Auto, *">
                                            
                                            <Border Grid.Column="0" Width="65" Height="50" CornerRadius="10" Background="#2C2C2C" Margin="0,0,15,0" Padding="5">
                                                <TextBlock Text="{Binding StationType}" Foreground="#00FF7F" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding Address}" Foreground="#AAAAAA" FontSize="14" Margin="0,5,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>